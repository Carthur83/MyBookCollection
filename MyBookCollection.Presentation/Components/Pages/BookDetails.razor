@page "/bookdetails"

<header class="navbar bg-primary">
    <div class="container-fluid d-flex px-3">
        <div class="d-flex text-light py-4 gap-2 w-100 align-items-center justify-content-center">
            <h1 class="fw-bold mb-0">Detaljer</h1>
        </div>
    </div>
</header>

<div class="px-3 py-3">
    <div class="book-image">
        <img class="book-image" src="/images/mist.png" alt="">
    </div>

    <div class="mt-3">
        <h3 class="fs-3 mb-1">The Mist</h3>
        <p class="author-details">Stephen King</p>
    </div>

    <div class="mt-4">
        <div class="d-flex gap-2 mt-2">
            <span class="badge rounded-pill badge-condition-good fs-14">Bra</span>
            <span class="badge rounded-pill badge-type fs-14">Inbunden</span>
        </div>
        <div class="mt-2">
            <span class="badge rounded-pill badge-type fs-14">Första utgåva 1979</span>
        </div>
    </div>

    <div class="mt-5">
        <h5>Beskrivning</h5>
        <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. In mollis, metus sit amet vulputate volutpat, nulla lorem efficitur turpis, in consequat sem elit eu nibh. </p>
    </div>

    <div class="d-flex flex-column gap-3 mt-6">
        <button type="button" class="btn btn-primary btn-custom d-flex gap-2 align-items-center justify-content-center">
            <i class="bi bi-pencil"></i> Uppdatera
        </button>
        <button type="button" class="btn btn-danger btn-custom d-flex gap-2 align-items-center justify-content-center">
            <i class="bi bi-trash"></i>
            Ta bort
        </button>
    </div>

</div>

