@page "/"
@using MyBookCollection.Business.Models
@inject IBookService BookService
@inject NavigationManager NavManager

    <nav class="navbar bg-primary">
        <div class="container-fluid d-flex px-3">
            <div class="d-flex text-light py-4 gap-2 w-100 align-items-center">
                <i class="bi bi-book h2 mb-0"></i>
                <h2 class="fw-bold mb-0">Min Samling</h2>
            <button class="btn ms-auto mb-0 text-light" data-bs-toggle="offcanvas" data-bs-target="#filterPanel">
                <i class="bi bi-funnel h2"></i>
            </button>
            </div>
            <form class="d-flex w-100 mb-3 position-relative" role="search">
                <i class="bi bi-search position-absolute"></i>
                <input class="form-control search-input input" type="search" placeholder="Sök" @bind-value="searchText" @bind-value:event="oninput" />
            </form>
        </div>
    </nav>

    <div class="px-3 py-3">
        <div class="d-flex w-100 align-items-end mt-2">
            <h3 class="fw-semibold fs-3 mb-0">Alla böcker</h3>
            <p class="small ms-auto mb-0">@filteredBooks.Count() böcker</p>
        </div>

        <div class="mt-4 d-flex flex-column gap-3 mb-6">
        @foreach (var book in filteredBooks)
        {
            <div class="book-card" @onclick="() => GoToDetails(book.Id)">
                <div class="img-container">
                    @if (!string.IsNullOrEmpty(book.ImageFileName))
                    {
                        <img src="@GetImage(book.ImageFileName)" alt="">                                         
                    }
                    else
                    {
                        <div class="no-image">
                            <span class="text-muted">Ingen bild</span>
                        </div>
                    }
                </div>
                <div class="card-info">
                    <h5 class="card-title fw-semibold">@book.Title</h5>
                    <p class="card-author">@book.Author</p>
                    <div class="d-flex gap-2 mt-2">
                        @switch(book.Condition)
                        {
                            case "Nyskick":
                                <span class="badge rounded-pill badge-condition-new">@book.Condition</span>
                                break;
                            case "Bra":
                                <span class="badge rounded-pill badge-condition-good">@book.Condition</span>
                                break;
                            case "Sliten":
                                <span class="badge rounded-pill badge-condition-worn">@book.Condition</span>
                                break;
                        }

                        <span class="badge rounded-pill badge-type">@book.Type</span>
                    </div>
                </div>
                <div class="d-flex align-items-center ms-auto">
                    <i class="bi bi-chevron-right"></i>
                </div>
            </div>
        }
            
        </div>

        <div class="offcanvas offcanvas-end" id="filterPanel">
            <div class="offcanvas-header">
                <h5>Filter</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas"></button>
            </div>

            <div class="offcanvas-body">

                <label>Skick</label>
                <select class="form-select" @bind="selectedCondition">
                    <option value="">Alla</option>
                    <option value="Nyskick">Nyskick</option>
                    <option value="Bra">Bra</option>
                    <option value="Sliten">Sliten</option>
                </select>

                <label class="mt-3">Typ</label>
                <select class="form-select" @bind="selectedType">
                    <option value="">Alla</option>
                    <option value="Pocket">Pocket</option>
                    <option value="Inbunden">Inbunden</option>
                </select>

            </div>
        </div>
    </div>

@code {
    public IEnumerable<BookModel> books = [];
    private string searchText = "";
    private string selectedCondition = "";
    private string selectedType = "";

    protected override async Task OnInitializedAsync()
    {
        books = await BookService.GetAllBooksAsync();
    }

    private IEnumerable<BookModel> filteredBooks => books
        .Where(b =>
            string.IsNullOrWhiteSpace(searchText) ||
            (b.Title?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (b.Author?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false)
        )
        .Where(b =>
            string.IsNullOrEmpty(selectedCondition) ||
            b.Condition == selectedCondition
        )
        .Where(b =>
            string.IsNullOrEmpty(selectedType) ||
            b.Type == selectedType
        );

    private string GetImage(string fileName)
    {
        if (string.IsNullOrEmpty(fileName))
            return null!;

        var path = Path.Combine(FileSystem.AppDataDirectory, "images", fileName);

        if (!File.Exists(path))
            return null!;

        var extension = Path.GetExtension(fileName).ToLower();
        var mimeType = extension switch
        {
            ".png" => "image/png",
            ".jpg" => "image/jpeg",
            ".jpeg" => "image/jpeg",
            _ => "image/jpeg"
        };

        var bytes = File.ReadAllBytes(path);
        var base64 = Convert.ToBase64String(bytes);

        return $"data:{mimeType};base64,{base64}";
    }

    public void GoToDetails(int id)
    {
        NavManager.NavigateTo($"bookdetails/{id}");
    }
}

